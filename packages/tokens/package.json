{
  "name": "@fresh/tokens",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nativewind": {
      "types": "./dist/nativewind.d.ts",
      "default": "./dist/nativewind.js"
    }
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup src/index.ts src/nativewind.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts packages/tokens/src --passWithNoTests"
  }
}
