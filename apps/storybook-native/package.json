{
  "name": "@fresh/storybook-native",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start --dev-client --clear",
    "start": "expo start --clear",
    "native:sync": "expo prebuild",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo export --platform android --output-dir dist",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts apps/storybook-native --passWithNoTests"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@fresh/recipes": "0.1.0",
    "@fresh/tokens": "0.1.0",
    "@fresh/ui": "0.1.0",
    "@fresh/ui-core": "0.1.0",
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "expo": "~53.0.9",
    "expo-dev-client": "~5.2.4",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-web": "~0.20.0",
    "react-native-svg": "15.11.2",
    "tailwindcss": "^3.4.17"
  }
}
