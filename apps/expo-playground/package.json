{
  "name": "@fresh-ds/expo-playground",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start --dev-client --clear",
    "start": "expo start --clear",
    "native:sync": "expo prebuild",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --clear",
    "build": "expo export --platform all --output-dir dist",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts apps/expo-playground --passWithNoTests"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@fresh-ds/tokens": "0.1.0",
    "@fresh-ds/ui": "0.1.0",
    "@fresh-ds/ui-core": "0.1.0",
    "expo": "~53.0.9",
    "expo-dev-client": "~5.2.4",
    "expo-status-bar": "~2.2.3",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-web": "~0.20.0",
    "react-native-svg": "15.11.2",
    "tailwindcss": "^3.4.17"
  }
}
